# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# OpenAI — needs Realtime API access
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime

# Twilio — must be a PAID/upgraded account (trial injects a spoken preamble)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Public tunnel hostname (ngrok/Cloudflare), no scheme — e.g. abcd-1234.ngrok-free.app
PUBLIC_HOSTNAME=

# Target test agent — DO NOT CHANGE. Hardcoded allowlist enforces this.
TARGET_NUMBER=+18054398008
